# SubsTrack bootstrap env
# Most runtime configuration now lives in MongoDB and can be managed from
# the dashboard settings page or via `pnpm setup`.

MONGODB_URI=mongodb://localhost:27017/substrack
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_ENABLED=true
TELEGRAM_ENABLED=true
NODE_ENV=development

# n450s_auth OIDC (advanced mode only — local mode ignores these)
# seed OAuth client from n450s_auth repo: `pnpm seed:sub5tr4cker` (or `npx ts-node scripts/seed-sub5tr4cker-client.ts`)
# optional: SUB5TR4CKER_REDIRECT_URIS=comma,separated,urls when seeding
# the secret is captured once at registration; store it in your deploy secret store, never here.
# use http://host.docker.internal:3045 when the app runs in Docker Desktop and n450s_auth runs on the host (localhost inside the container is not your Mac)
AUTH_SERVICE_URL=http://localhost:3045
OAUTH_CLIENT_ID=sub5tr4cker
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URIS=http://localhost:3054/api/auth/n450s/callback
