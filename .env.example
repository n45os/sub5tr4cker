# ===========================================
# SubsTrack — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/substrack

# --- Auth.js (NextAuth v5) ---
NEXTAUTH_SECRET=          # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional, for "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=           # get one at https://resend.com
EMAIL_FROM=SubsTrack <noreply@yourdomain.com>

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=       # get from @BotFather on Telegram
TELEGRAM_WEBHOOK_SECRET=  # random secret for webhook verification

# --- Security ---
CONFIRMATION_SECRET=      # HMAC secret for "I paid" email links. generate: openssl rand -base64 32
CRON_SECRET=              # secret header value for cron API routes. generate: openssl rand -base64 32

# --- App ---
APP_URL=http://localhost:3000
NODE_ENV=development
